ARG BASE_IMAGE=ayushsingh23/deeptrace-ml:latest
FROM ${BASE_IMAGE}

LABEL maintainer="DeepTrace Team"
LABEL description="DeepTrace Celery Worker"

USER root
COPY app/ ./app/
COPY wsgi.py .
RUN chown -R deeptrace:deeptrace /app

USER deeptrace

CMD ["celery", "-A", "app.extensions.celery", "worker", \
     "--loglevel=info", "--concurrency=2", "--max-tasks-per-child=50"]