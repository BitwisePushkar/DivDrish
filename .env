# ─── DeepTrace Flask Backend Environment Variables ────────
# Copy this file to .env and fill in your values

# ─── Flask Settings ──────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# ─── API Keys (comma-separated, leave empty to disable auth) ─
API_KEYS=your_api_key_here

# ─── JWT Settings ────────────────────────────────────────
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# ─── Database URL (PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/deeptrace

# ─── Celery / Redis ─────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT=100/minute
RATELIMIT_STORAGE_URI=memory://

# ─── Detection Thresholds ───────────────────────────────
VIDEO_THRESHOLD=0.70
AUDIO_THRESHOLD=0.65
IMAGE_THRESHOLD=0.72

# ─── Upload Limits (MB) ─────────────────────────────────
MAX_VIDEO_MB=200
MAX_AUDIO_MB=50
MAX_IMAGE_MB=20

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── Gunicorn ────────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
