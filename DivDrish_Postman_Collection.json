						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"reset_token\": \"paste-reset-token-here\",\n  \"new_password\": \"NewSecurePass456!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/password-reset/confirm",
							"host": ["{{base_url}}"],
							"path": ["auth", "password-reset", "confirm"]
						}
					},
					"response": []
				}
			]
